{
  "name": "hackscriptai",
  "private": true,
  "version": "2.0.6",
  "type": "module",
  "main": "main.cjs",
  "build": {
    "appId": "com.aistudio.comfyui.assistant",
    "productName": "HackScriptAI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.cjs"
    ],
    "extraResources": [
      {
        "from": "WorkFlowSample",
        "to": "WorkFlowSample",
        "filter": ["**/*"]
      },
      {
        "from": ".",
        "to": ".",
        "filter": [
          "Start.command",
          "Start_Win.bat"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "electron:start": "NODE_ENV=development electron .",
    "electron:pack": "npm run build && electron-builder",
    "postinstall": "node -e \"require('fs').chmodSync('Start.command', '755'); require('fs').chmodSync('Build_Mac.command', '755')\" || true"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "docx": "^9.6.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "firebase": "^12.12.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.38.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
